# Copy to .env.local and adjust.

# Base URL of the Beerio Kart API (the C++ Crow server in apps/server).
# Default matches the server's PORT default (8080).
NEXT_PUBLIC_API_URL=http://localhost:8080

# When "true", always use the in-memory mock client (no network calls).
# When "false", use the real API but transparently fall back to mock data if
# the server is unreachable (connection errors only — 4xx errors still surface).
NEXT_PUBLIC_USE_MOCK=false
